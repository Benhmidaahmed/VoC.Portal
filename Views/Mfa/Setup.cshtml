@model Xrmbox.VoC.Portal.ViewModels.MfaSetupViewModel

@{
    ViewData["Title"] = "Configuration de l'authentification à deux facteurs";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <h1 class="mb-3">Configuration de l'authentification à deux facteurs</h1>
            <p class="text-muted mb-4">
                Scannez le QR Code avec Google Authenticator, puis saisissez le code à 6 chiffres pour valider.
            </p>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <img class="img-fluid" alt="QR Code MFA"
                         src="data:image/png;base64,@Model.QrCodeBase64" />
                </div>
            </div>

            <form asp-action="Verify" method="post">
                <input type="hidden"
                       name="returnUrl"
                       value="@ViewContext.HttpContext.Request.Query["returnUrl"]" />

                <div class="form-group">
                    <label>Code de vérification</label>
                    <input name="code" class="form-control" autocomplete="off" />
                </div>
                <button type="submit" class="btn btn-primary">Vérifier</button>
            </form>
        </div>
    </div>
</div>
