@{
    ViewData["Title"] = "Survey";
    var surveyId = Context.Request.Query["id"].ToString();
    var participantId = Context.Request.Query["participantId"].ToString();
    var campagneId = Context.Request.Query["campagneId"].ToString();
}

@section Styles {
    @* CSS de SurveyJS *@
    <link href="https://cdn.jsdelivr.net/npm/survey-core/survey.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/survey-core/defaultV2.min.css" rel="stylesheet" />
}

<div class="container">
    <div class="py-4">
        <div id="surveyContainer">Chargement du questionnaire…</div>
    </div>
    <div id="resultContainer" style="margin-top:16px;"></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/survey-jquery/survey.jquery.min.js"></script>

    <script>
        (function () {
            // Appliquer le thème AVANT tout
            Survey.StylesManager.applyTheme("defaultV2");

            const surveyId = '@surveyId';
            const participantId = '@participantId';
            const campagneId = '@campagneId';

            if (!surveyId) {
                document.getElementById('surveyContainer').innerText = "ID du questionnaire manquant.";
                return;
            }

            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)
                .then(response => {
                    if (!response.ok) throw new Error('Erreur API');
                    return response.json();
                })
                .then(json => {
                    const survey = new Survey.Model(json);

                         survey.onComplete.add(function (sender) {
                        const payload = {
                            // On utilise des MAJUSCULES pour correspondre au modèle C#
                            SurveyId: surveyId,
                            ParticipantId: participantId || null,
                            CampagneId: campagneId || null,
                            ResponseJson: JSON.stringify(sender.data)
                        };  

                        fetch('/api/responses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        }).then(r => {
                            if (r.ok) {
                                document.getElementById('surveyContainer').innerHTML = "<h4>Merci !</h4>";
                            }
                        });
                    });

                    $("#surveyContainer").Survey({ model: survey });
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById('surveyContainer').innerText = "Erreur de chargement.";
                });
        })();
    </script>
}