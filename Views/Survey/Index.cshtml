@{
    Layout = null;
    var surveyId = (ViewBag.SurveyId ?? string.Empty).ToString();
    var participantId = (ViewBag.ParticipantId ?? string.Empty).ToString();
    var token = (ViewBag.Token ?? string.Empty).ToString();
    var campagneId = (ViewBag.CampagneId ?? string.Empty).ToString();
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Questionnaire de Satisfaction - XRMBOX</title>

    <link href="https://unpkg.com/survey-jquery/defaultV2.min.css" rel="stylesheet" />

    <style>
        :root {
            --primary-blue: #2e2e8e;
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 20px;
        }

        .survey-wrapper {
            width: 100%;
            max-width: 1100px; /* Pour bien occuper l'espace comme sur tes dessins */
        }

        #surveyContainer {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            padding: 25px;
        }

        /* --- CORRECTION ALIGNEMENT TITRE --- */
        .sd-header__title {
            text-align: center !important; /* Centre le titre "Questionnaire de satisfaction" */
            width: 100%;
        }

        /* --- CORRECTION LARGEUR INTERNE --- */
        .sd-container-modern {
            max-width: 100% !important;
        }

        .sd-root-modern {
            --sd-primary: var(--primary-blue);
            --sd-primary-light: rgba(46, 46, 142, 0.1);
            --sd-border-radius: 12px;
            --sd-base-vertical-unit: 14px; /* Un peu plus d'espace pour la lisibilité */
        }

        .loading-state {
            text-align: center;
            padding: 60px;
            color: var(--primary-blue);
            font-weight: 600;
            font-size: 1.2rem;
        }

        .footer-brand {
            text-align: center;
            margin-top: 30px;
            font-size: 0.9rem;
            color: #444;
            opacity: 0.8;
            padding-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="survey-wrapper">
        <div id="surveyContainer">
            <div class="loading-state">
                Chargement de votre questionnaire...
            </div>
        </div>

        <div class="footer-brand">
            Propulsé par <strong>XRMBOX VoC Portal</strong>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/survey-jquery/survey.jquery.min.js"></script>

    <script>
        (function () {
            // Appliquer le thème moderne
            Survey.StylesManager.applyTheme("modern");

            const surveyId = '@surveyId';
            const participantId = '@participantId';
            const token = '@token';
            const campagneId = '@campagneId';

            const rawSavedData = `@Html.Raw(ViewBag.SavedData ?? "null")`;
            let savedData = null;
            try {
                if (rawSavedData !== "null") savedData = JSON.parse(rawSavedData);
            } catch (e) { console.log("Pas de données partielles."); }

            if (!surveyId) {
                document.getElementById('surveyContainer').innerHTML = "<div class='loading-state'>Erreur : Identifiant de questionnaire manquant.</div>";
                return;
            }

            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)
                .then(response => {
                    if (!response.ok) throw new Error('Erreur API');
                    return response.json();
                })
                .then(json => {
                    const survey = new Survey.Model(json);

                    // Optionnel : Forcer le titre à être plus grand via JS si besoin
                    survey.title = json.title || "Questionnaire de satisfaction";

                    if (savedData) survey.data = savedData;

                    // Sauvegarde partielle
                    let saveTimeout = null;
                    survey.onValueChanged.add(function (sender) {
                        if (!token) return;
                        if (saveTimeout) clearTimeout(saveTimeout);
                        saveTimeout = setTimeout(function () {
                            const payload = {
                                token: token,
                                jsonData: JSON.stringify(sender.data)
                            };
                            fetch('/Survey/SavePartial', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams(payload)
                            });
                        }, 2000);
                    });

                    // Envoi final
                    survey.onComplete.add(function (sender) {
                        const payload = {
                            SurveyId: surveyId,
                            ParticipantId: participantId || null,
                            CampagneId: campagneId || null,
                            ResponseJson: JSON.stringify(sender.data),
                            Token: token || null
                        };

                        fetch('/api/responses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        })
                        .then((r) => {
                            if (r.ok) {
                                document.getElementById('surveyContainer').innerHTML =
                                    "<div style='padding:80px 20px; text-align:center;'> <h2 style='color:var(--primary-blue);'>Merci de votre participation !</h2><p>Vos réponses ont été transmises avec succès à nos équipes.</p></div>";
                            } else {
                                alert("Une erreur est survenue lors de l'enregistrement final.");
                            }
                        });
                    });

                    // Rendu dans le conteneur
                    $("#surveyContainer").Survey({ model: survey });
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById('surveyContainer').innerHTML = "<div class='loading-state'>Impossible de charger le questionnaire.</div>";
                });
        })();
    </script>
</body>
</html>