@{
    Layout = null;
    var surveyId = (ViewBag.SurveyId ?? string.Empty).ToString();
    var participantId = (ViewBag.ParticipantId ?? string.Empty).ToString();
    var token = (ViewBag.Token ?? string.Empty).ToString();
    var campagneId = (ViewBag.CampagneId ?? string.Empty).ToString();

    // Récupération du HTML de la campagne
    string designHtml = ViewBag.PageDesignHtml?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Questionnaire de Satisfaction - XRMBOX</title>

    <link href="https://unpkg.com/survey-jquery/defaultV2.min.css" rel="stylesheet" />

    <style>
        /* Styles de secours si le design Unlayer est vide */
        :root {
            --primary-blue: #2e2e8e;
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Conteneur SurveyJS quand il est injecté */
        #surveyElement {
            width: 100%;
            background: #ffffff;
            border-radius: 12px;
            overflow: hidden;
        }

        .loading-state {
            text-align: center;
            padding: 60px;
            color: #2e2e8e;
            font-weight: 600;
        }
    </style>
</head>
<body>

    @if (!string.IsNullOrEmpty(designHtml) && designHtml.Contains("{{SURVEY_HERE}}"))
    {
        @* IMPORTANT : On remplace le texte de substitution par le vrai conteneur SurveyJS 
           dans le HTML généré par l'éditeur Unlayer.
        *@
        @Html.Raw(designHtml.Replace("{{SURVEY_HERE}}", "<div id='surveyElement'><div class='loading-state'>Chargement du questionnaire...</div></div>"))
    }
    else
    {
        <div style="background: var(--bg-gradient); min-height: 100vh; padding: 40px 20px; display: flex; justify-content: center;">
            <div style="width: 100%; max-width: 1100px;">
                <div id="surveyElement">
                    <div class="loading-state">Chargement du questionnaire...</div>
                </div>
            </div>
        </div>
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/survey-jquery/survey.jquery.min.js"></script>

    <script>
        (function () {
            "use strict";
            Survey.StylesManager.applyTheme("modern");

            const surveyId = '@surveyId';
            const participantId = '@participantId';
            const token = '@token';
            const campagneId = '@campagneId';

            const rawSavedData = `@Html.Raw(ViewBag.SavedData ?? "null")`;
            let savedData = null;
            try {
                if (rawSavedData !== "null") savedData = JSON.parse(rawSavedData);
            } catch (e) { console.log("Pas de données partielles."); }

            if (!surveyId) {
                const el = document.getElementById('surveyElement');
                if(el) el.innerHTML = "<div class='loading-state'>Erreur : ID manquant.</div>";
                return;
            }

            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)
                .then(response => {
                    if (!response.ok) throw new Error('Erreur API');
                    return response.json();
                })
                .then(json => {
                    const survey = new Survey.Model(json);
                    survey.title = json.title || "Questionnaire de satisfaction";
                    if (savedData) survey.data = savedData;

                    // Sauvegarde partielle automatique
                    let saveTimeout = null;
                    survey.onValueChanged.add(function (sender) {
                        if (!token) return;
                        if (saveTimeout) clearTimeout(saveTimeout);
                        saveTimeout = setTimeout(function () {
                            const payload = {
                                token: token,
                                jsonData: JSON.stringify(sender.data)
                            };
                            fetch('/Survey/SavePartial', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams(payload)
                            });
                        }, 2000);
                    });

                    // Envoi final
                    survey.onComplete.add(function (sender) {
                        const payload = {
                            SurveyId: surveyId,
                            ParticipantId: participantId || null,
                            CampagneId: campagneId || null,
                            ResponseJson: JSON.stringify(sender.data),
                            Token: token || null
                        };

                        fetch('/api/responses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        })
                        .then((r) => {
                            if (r.ok) {
                                document.getElementById('surveyElement').innerHTML =
                                    "<div style='padding:80px 20px; text-align:center;'> <h2 style='color:#2e2e8e;'>Merci !</h2><p>Vos réponses ont été enregistrées.</p></div>";
                            } else {
                                alert("Erreur lors de l'envoi.");
                            }
                        });
                    });

                    // Rendu dans l'élément injecté
                    $("#surveyElement").Survey({ model: survey });
                })
                .catch(err => {
                    console.error(err);
                    const el = document.getElementById('surveyElement');
                    if(el) el.innerHTML = "<div class='loading-state'>Impossible de charger le questionnaire.</div>";
                });
        })();
    </script>
</body>
</html>