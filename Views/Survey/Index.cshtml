@{
    ViewData["Title"] = "Survey";

    // Utiliser les valeurs passées par le controller via ViewBag
    var surveyId = (ViewBag.SurveyId ?? string.Empty).ToString();
    var participantId = (ViewBag.ParticipantId ?? string.Empty).ToString();
    var token = (ViewBag.Token ?? string.Empty).ToString();
    var campagneId = (ViewBag.CampagneId ?? string.Empty).ToString();
    // ViewBag.SavedData peut contenir du JSON (objet) ou null
}

@section Styles {
    @* CSS de SurveyJS *@
    
    <link href="https://unpkg.com/survey-jquery/defaultV2.min.css" rel="stylesheet" />
    <style>
        .sv-root-modern {
            background: white;
            padding: 20px;
            border-radius: 10px;
        }

        .sv-container-modern {
            max-width: 800px;
            margin: auto;
        }
    </style>

}

<div class="container">
    <div class="py-4">
        <div id="surveyContainer">Chargement du questionnaire…</div>
    </div>
    <div id="resultContainer" style="margin-top:16px;"></div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/survey-jquery/survey.jquery.min.js"></script>
    <script>
        (function () {
            Survey.StylesManager.applyTheme("defaultV2");

            const surveyId = '@surveyId';
            const participantId = '@participantId';
            const token = '@token';
            const campagneId = '@campagneId';

            // Correction 1: Injection sécurisée du JSON
            const rawSavedData = `@Html.Raw(ViewBag.SavedData ?? "null")`;
            let savedData = null;
            if (rawSavedData !== "null") {
                try {
                    savedData = JSON.parse(rawSavedData);
                } catch (e) {
                    // Si c'est déjŕ un objet (selon comment le controller l'envoie)
                    savedData = @Html.Raw(ViewBag.SavedData ?? "null");
                }
            }

            if (!surveyId) {
                document.getElementById('surveyContainer').innerText = "ID du questionnaire manquant.";
                return;
            }

            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)
                .then(response => {
                    if (!response.ok) throw new Error('Erreur API');
                    return response.json();
                })
                .then(json => {
                    const survey = new Survey.Model(json);

                    if (savedData) {
                        survey.data = savedData;
                    }

                    let saveTimeout = null;
                    survey.onValueChanged.add(function (sender) {
                        if (!token) return;

                        if (saveTimeout) clearTimeout(saveTimeout);
                        saveTimeout = setTimeout(function () {
                            const payload = {
                                token: token,
                                jsonData: JSON.stringify(sender.data)
                            };

                            // Attention : vérifie si ton API est /api/responses/partial ou /Survey/SavePartial
                            fetch('/Survey/SavePartial', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams(payload)
                            });
                        }, 1000);
                    });

                    survey.onComplete.add(function (sender) {
                        const payload = {
                            SurveyId: surveyId,
                            ParticipantId: participantId || null,
                            CampagneId: campagneId || null,
                            ResponseJson: JSON.stringify(sender.data),
                            Token: token || null
                        };

                        fetch('/api/responses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        })
                        // CORRECTION ICI : Ajout des parenthčses (r) =>
                        .then((r) => {
                            if (r.ok) {
                                document.getElementById('surveyContainer').innerHTML = "<h4>Merci !</h4>";
                            } else {
                                document.getElementById('surveyContainer').innerHTML = "<h4>Erreur lors de l'enregistrement.</h4>";
                            }
                        })
                        .catch(err => console.error("Erreur finale:", err));
                    });

                    $("#surveyContainer").Survey({ model: survey });
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById('surveyContainer').innerText = "Erreur de chargement.";
                });
        })();
    </script>
}