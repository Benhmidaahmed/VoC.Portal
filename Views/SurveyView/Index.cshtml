@{

    ViewData["Title"] = "Questionnaire";

}



<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <title>@ViewData["Title"]</title>



    <!-- SurveyJS CSS -->

    <link href="https://unpkg.com/survey-core/defaultV2.min.css" rel="stylesheet" />



    <style>

        #surveyContainer {
            margin: 24px;
        }

    </style>

</head>

<body>

    <div class="container">

        <h2>@ViewData["Title"]</h2>

        <div id="surveyContainer">Chargement du questionnaireÖ</div>

        <div id="resultContainer" style="margin-top:16px;"></div>

    </div>



    <!-- jQuery + SurveyJS (survey-jquery dťpend de jQuery) -->

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script src="https://unpkg.com/survey-jquery/survey.jquery.min.js"></script>



    <script>

        (function () {

            function getQueryParam(name) {

                const url = new URL(window.location.href);

                return url.searchParams.get(name);

            }



            const surveyId = getQueryParam('id');

            const participantId = getQueryParam('participantId');

            const campagneId = getQueryParam('campagneId');



            if (!surveyId) {

                document.getElementById('surveyContainer').innerText = "ID du questionnaire manquant (paramŤtre ?id=).";

                return;

            }



            // Charger le JSON depuis votre API existante

            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)

                .then(r => {

                    if (!r.ok) throw new Error('Impossible de charger le questionnaire.');

                    return r.json();

                })

                .then(json => {

                    const survey = new Survey.Model(json);



                    survey.onComplete.add(function (sender) {

                        const answers = sender.data;

                        const payload = {

                            SurveyId: surveyId,

                            ParticipantId: participantId || null,

                            CampagneId: campagneId || null,

                            ResponseJson: JSON.stringify(answers)

                        };



                        fetch('/api/responses', {

                            method: 'POST',

                            headers: { 'Content-Type': 'application/json' },

                            body: JSON.stringify(payload)

                        })

                            .then(async r => {

                                const body = await r.json().catch(() => ({}));

                                if (r.ok) {

                                    document.getElementById('surveyContainer').innerHTML = "<h4>Merci ó vos rťponses ont ťtť enregistrťes.</h4>";

                                    document.getElementById('resultContainer').innerHTML = "<pre>ID: " + (body.id ?? "") + "</pre>";

                                } else {

                                    document.getElementById('resultContainer').innerHTML = "<pre>Erreur: " + JSON.stringify(body) + "</pre>";

                                }

                            })

                            .catch(err => {

                                document.getElementById('resultContainer').innerHTML = "<pre>Erreur rťseau lors de l'envoi: " + err + "</pre>";

                            });

                    });



                    survey.render('surveyContainer');

                })

                .catch(err => {

                    console.error(err);

                    document.getElementById('surveyContainer').innerText = "Erreur lors du chargement du questionnaire.";

                });

        })();

    </script>

</body>

</html>