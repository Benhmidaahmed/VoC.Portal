@{
    ViewData["Title"] = "Questionnaire";
    var surveyId = Context.Request.Query["id"].ToString();
}

@section Styles {
    @* Chargement des styles SurveyJS moderne (V2) *@
    <link href="https://unpkg.com/survey-core/defaultV2.min.css" rel="stylesheet" />
    <style>
        #surveyContainer {
            margin-top: 20px;
            min-height: 500px;
        }
    </style>
}

<div class="container">
    <h2>@ViewData["Title"]</h2>
    <div id="surveyContainer">Chargement du questionnaire...</div>
    <div id="resultContainer"></div>
</div>

@section Scripts {
    @* On utilise la version jQuery de SurveyJS *@
    <script src="https://unpkg.com/survey-jquery/survey.jquery.min.js"></script>

    <script>
        (function () {
            // 1. Appliquer le thĶme visuel
            Survey.StylesManager.applyTheme("defaultV2");

            const surveyId = "@surveyId";
            if (!surveyId) {
                $("#surveyContainer").html("<div class='alert alert-danger'>ID manquant.</div>");
                return;
            }

            // 2. Rķcupķrer le JSON du questionnaire
            fetch(`/api/surveys/${encodeURIComponent(surveyId)}`)
                .then(r => r.json())
                .then(json => {
                    const survey = new Survey.Model(json);

                    // 3. Gķrer la fin du questionnaire
                    survey.onComplete.add(function (sender) {
                        const payload = {
                            SurveyId: surveyId,
                            ResponseJson: JSON.stringify(sender.data)
                        };

                        fetch('/api/responses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        }).then(res => {
                            if(res.ok) {
                                $("#surveyContainer").html("<h3>Merci pour votre participation !</h3>");
                            }
                        });
                    });

                    // 4. Afficher le questionnaire dans la div
                    $("#surveyContainer").Survey({ model: survey });
                })
                .catch(err => {
                    console.error(err);
                    $("#surveyContainer").text("Erreur lors du chargement.");
                });
        })();
    </script>
}